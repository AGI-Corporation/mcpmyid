{
    "workflow_name": "Blended CRM & Support Agent",
    "agent_config": {
        "model": "gpt-4o",
        "optimization": "CACTUS_7_LAYER",
        "virtual_tools": [
            {
                "name": "SmartSupport",
                "description": "Blends CRM lookups with instant Slack notifications.",
                "base_actions": [
                    { "piece": "hubspot", "action": "find_contact" },
                    { "piece": "slack", "action": "send_message" }
                ],
                "rule_sets": [
                    {
                        "description": "Ensure Slack channel is set if HubSpot contact is high-value.",
                        "conditions": [
                            { "name": "hubspot_find_contact_lifecycleStage", "state": "set_to_value", "value": "subscriber" }
                        ],
                        "targets": [
                            { "name": "slack_send_message_channel", "state": "set" }
                        ]
                    }
                ]
            }
        ]
    },
    "protocol": "NANDA/AgentFacts-1.0"
}
